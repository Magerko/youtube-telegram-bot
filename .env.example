# Скопируйте этот файл в .env и заполните значениями.
# .env в репозиторий не коммитится (см. .gitignore).

# Токен Telegram-бота. Получить у @BotFather: /newbot → следовать инструкциям.
TELEGRAM_BOT_TOKEN=

# Ключ YouTube Data API v3.
# https://console.cloud.google.com → New Project → APIs & Services → Library →
# YouTube Data API v3 → Enable → Credentials → Create credentials → API key.
YOUTUBE_API_KEY=

# Telegram user ID администраторов через запятую (без пробелов).
# Свой ID можно узнать у @userinfobot или @getmyid_bot.
ADMIN_USERS=

# Интервал проверки новых видео в секундах. По умолчанию 300 (5 минут).
CHECK_INTERVAL=300

# Папка для JSON-данных (создаётся автоматически).
DATA_FOLDER=pydata

# Опционально: Redis для хранения FSM-состояний.
# Если не задан — используется MemoryStorage (теряется при рестарте).
# При запуске через docker-compose выставляется автоматически.
# REDIS_URL=redis://localhost:6379/0
